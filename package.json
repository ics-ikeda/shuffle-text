{
  "name": "shuffle-text",
  "version": "0.6.0",
  "scripts": {
    "build": "rolldown -c rolldown.config.js",
    "watch": "rolldown -c rolldown.config.js --watch",
    "build:d.ts": "tsc --emitDeclarationOnly --declarationDir ./build",
    "build:docs": "typedoc --html ./docs ./src/ShuffleText.ts",
    "format": "oxfmt --write 'src/**/*.ts'"
  },
  "devDependencies": {
    "oxfmt": "0.58.0",
    "rolldown": "1.1.5",
    "typedoc": "1.0.0-dev.4",
    "typescript": "7.0.2"
  },
  "type": "module",
  "main": "build/shuffle-text.js",
  "jsnext:main": "build/shuffle-text.module.js",
  "module": "build/shuffle-text.module.js",
  "types": "build/ShuffleText.d.ts",
  "license": "MIT",
  "description": "This is the JavaScript library for text effect such as Flash contents.",
  "repository": "ics-ikeda/shuffle-text",
  "author": "IKEDA Yasunobu <ikeda@ics-web.jp> (https://clockmaker.jp/labs/)",
  "homepage": "https://github.com/ics-ikeda/shuffle-text",
  "keywords": [
    "JavaScript",
    "TypeScript",
    "shuffle-text",
    "text effect"
  ]
}
